{
  "tasks": {
    "build": "deno run --unstable-bundle --allow-read --allow-write --allow-env --allow-net build.ts",
    "dev": "deno task build --watch",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check build.ts selfcheck.ts src/main.ts",
    "test": "deno test selfcheck.ts"
  },
  "imports": {
    "three": "npm:three@0.160.0",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "strict": true
  },
  "fmt": {
    "include": ["src/", "build.ts", "selfcheck.ts", "deno.json"]
  },
  "lint": {
    "include": ["src/", "build.ts", "selfcheck.ts"],
    "rules": {
      "exclude": ["no-window", "no-window-prefix"]
    }
  }
}
